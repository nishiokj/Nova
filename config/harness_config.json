{
  "agents": {
    "routing": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5-mini",
        "max_tokens": 200,
        "temperature": 0.1
      },
      "budget": {
        "max_iterations": 1,
        "max_tool_calls": 0,
        "max_duration_ms": 3000
      },
      "output_schema": "routing"
    },
    "simple": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5-nano",
        "max_tokens": 4000,
        "temperature": 0.5
      },
      "budget": {
        "max_iterations": 1,
        "max_tool_calls": 0,
        "max_duration_ms": 3000
      },
      "output_schema": "agent_action"
    },
    "explorer": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5-mini",
        "max_tokens": 100000,
        "temperature": 0.3
      },
      "budget": {
        "max_iterations": 3,
        "max_tool_calls": 40,
        "max_duration_ms": 30000
      },
      "tools": ["Read", "Glob", "Grep", "Bash"],
      "output_schema": "explorer"
    },
    "runtime_script": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5.2",
        "max_tokens": 16000,
        "temperature": 0.5,
        "reasoning": { "effort": "medium" }
      },
      "budget": {
        "max_iterations": 2,
        "max_tool_calls": 15,
        "max_duration_ms": 30000
      },
      "tools": ["explorer", "standard", "coding-agent"],
      "output_schema": "runtime_script"
    },
    "standard": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5.2",
        "max_tokens": 16000,
        "temperature": 0.7
      },
      "budget": {
        "max_iterations": 10,
        "max_tool_calls": 150,
        "max_duration_ms": 120000
      },
      "tools": ["Read", "Write", "Edit", "Glob", "Grep", "Bash", "coding-agent", "explorer", "runtime_script"],
      "output_schema": "goal_driven"
    },
    "coding-agent": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5.2-codex",
        "max_tokens": 128000,
        "temperature": 0.7,
        "reasoning": { "effort": "high" }
      },
      "budget": {
        "max_iterations": 20,
        "max_tool_calls": 100,
        "max_duration_ms": 5000000
      },
      "tools": ["Read", "Write", "Edit", "Glob", "Grep", "Bash", "standard"],
      "output_schema": "goal_driven"
    },
    "context_compactor": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5-nano",
        "max_tokens": 200000,
        "temperature": 0.3
      },
      "budget": {
        "max_iterations": 2,
        "max_tool_calls": 0,
        "max_duration_ms": 30000
      },
      "output_schema": "agent_action"
    },
    "debugger": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5.2",
        "max_tokens": 16000,
        "temperature": 0.5
      },
      "budget": {
        "max_iterations": 10,
        "max_tool_calls": 15,
        "max_duration_ms": 120000
      },
      "tools": ["Read", "Write", "Edit", "Glob", "Grep", "Bash"],
      "output_schema": "agent_action"
    },
    "web_crawler": {
      "llm": {
        "provider": "openai",
        "model": "gpt-5-mini",
        "max_tokens": 8000,
        "temperature": 0.5
      },
      "budget": {
        "max_iterations": 10,
        "max_tool_calls": 15,
        "max_duration_ms": 120000
      },
      "tools": ["WebFetch", "WebSearch"],
      "output_schema": "agent_action"
    }
  },
  "tools": {
    "bash_timeout_ms": 30000,
    "max_output_length": 10000
  },
  "graphd": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 9444,
    "db_path": ".graphd/graphd.db"
  },
  "context": {
    "max_tokens": 200000
  },
  "skills": {
    "enabled": true,
    "directory": "config/skills"
  },
  "hooks": {
    "enabled": true,
    "directory": "config/hooks"
  }
}
