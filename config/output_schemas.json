{
  "$comment": "Output schema definitions. Referenced by harness_config.json agents via 'output_schema' key.",

  "components": {
    "user_prompt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "question": { "type": "string" },
        "options": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "anyOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "label": { "type": "string" },
                      "description": { "type": ["string", "null"] }
                    },
                    "required": ["label", "description"]
                  }
                ]
              }
            },
            { "type": "null" }
          ]
        },
        "context": { "type": ["string", "null"] },
        "multiSelect": { "type": ["boolean", "null"] }
      },
      "required": ["question", "options", "context", "multiSelect"]
    },
    "user_prompt_nullable": {
      "anyOf": [
        { "$ref": "#/components/user_prompt" },
        { "type": "null" }
      ]
    }
  },

  "schemas": {
    "routing": {
      "name": "routing_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "tier": {
            "type": "string",
            "enum": ["simple", "standard", "complex"]
          }
        },
        "required": ["tier"]
      }
    },

    "agent_action": {
      "name": "agent_action_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "action": {
            "type": "string",
            "enum": ["done", "need_user_input", "continue", "handoff"]
          },
          "response": { "type": ["string", "null"] },
          "goalStateReached": { "type": ["boolean", "null"] },
          "userPrompt": {
            "anyOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "question": { "type": "string" },
                  "options": {
                    "anyOf": [
                      {
                        "type": "array",
                        "items": {
                          "anyOf": [
                            { "type": "string" },
                            {
                              "type": "object",
                              "additionalProperties": false,
                              "properties": {
                                "label": { "type": "string" },
                                "description": { "type": ["string", "null"] }
                              },
                              "required": ["label", "description"]
                            }
                          ]
                        }
                      },
                      { "type": "null" }
                    ]
                  },
                  "context": { "type": ["string", "null"] },
                  "multiSelect": { "type": ["boolean", "null"] }
                },
                "required": ["question", "options", "context", "multiSelect"]
              },
              { "type": "null" }
            ]
          }
        },
        "required": ["action", "response", "goalStateReached", "userPrompt"]
      }
    },

    "goal_driven": {
      "name": "goal_driven_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "action": {
            "type": "string",
            "enum": ["done", "need_user_input", "continue"]
          },
          "response": { "type": ["string", "null"] },
          "goalStateReached": { "type": ["boolean", "null"] },
          "userPrompt": {
            "anyOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "question": { "type": "string" },
                  "options": {
                    "anyOf": [
                      {
                        "type": "array",
                        "items": {
                          "anyOf": [
                            { "type": "string" },
                            {
                              "type": "object",
                              "additionalProperties": false,
                              "properties": {
                                "label": { "type": "string" },
                                "description": { "type": ["string", "null"] }
                              },
                              "required": ["label", "description"]
                            }
                          ]
                        }
                      },
                      { "type": "null" }
                    ]
                  },
                  "context": { "type": ["string", "null"] },
                  "multiSelect": { "type": ["boolean", "null"] }
                },
                "required": ["question", "options", "context", "multiSelect"]
              },
              { "type": "null" }
            ]
          },
          "work_done": { "type": ["string", "null"], "description": "Concrete work completed this turn: files read, edits made, commands run. NOT plans or intentions." }
        },
        "required": ["action", "response", "goalStateReached", "userPrompt", "work_done"]
      }
    },

    "explorer": {
      "name": "explorer_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "action": {
            "type": "string",
            "enum": ["done", "need_user_input", "continue"]
          },
          "response": { "type": ["string", "null"] },
          "goalStateReached": { "type": ["boolean", "null"] },
          "userPrompt": {
            "anyOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "question": { "type": "string" },
                  "options": {
                    "anyOf": [
                      {
                        "type": "array",
                        "items": {
                          "anyOf": [
                            { "type": "string" },
                            {
                              "type": "object",
                              "additionalProperties": false,
                              "properties": {
                                "label": { "type": "string" },
                                "description": { "type": ["string", "null"] }
                              },
                              "required": ["label", "description"]
                            }
                          ]
                        }
                      },
                      { "type": "null" }
                    ]
                  },
                  "context": { "type": ["string", "null"] },
                  "multiSelect": { "type": ["boolean", "null"] }
                },
                "required": ["question", "options", "context", "multiSelect"]
              },
              { "type": "null" }
            ]
          },
          "handoffSpec": { "type": ["string", "null"] },
          "packageManagers": { "type": "array", "items": { "type": "string" } },
          "frameworks": { "type": "array", "items": { "type": "string" } },
          "languages": { "type": "array", "items": { "type": "string" } },
          "os": { "type": "string" },
          "artifacts": {
            "type": "array",
            "description": "Semantic code artifacts extracted from source files. Each artifact must specify which uncertainty category it reduces.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "sourcePath": { "type": "string", "description": "File path where this artifact was found" },
                "line": { "type": ["integer", "null"], "description": "Line number for navigation" },
                "kind": {
                  "type": "string",
                  "enum": ["function", "class", "interface", "import", "export", "constant", "pattern", "summary"],
                  "description": "What type of code construct this represents"
                },
                "name": { "type": "string", "description": "Name of the artifact (function name, class name, etc.)" },
                "signature": { "type": ["string", "null"], "description": "Full type signature (e.g., 'async run(params: RunParams): Promise<Result>')" },
                "modifies": {
                  "type": ["array", "null"],
                  "items": { "type": "string" },
                  "description": "Side effects: state, files, globals this touches (e.g., [\"this._items\", \"fs:config.json\", \"db:users\"])"
                },
                "calls": {
                  "type": ["array", "null"],
                  "items": { "type": "string" },
                  "description": "Call graph: significant functions this invokes (e.g., [\"llm.complete\", \"tools.execute\"])"
                },
                "insight": {
                  "type": ["string", "null"],
                  "description": "Non-obvious info NOT derivable from name/signature (e.g., \"Retries 3x with exponential backoff\")"
                },
                "reduces": {
                  "type": ["string", "null"],
                  "enum": ["structural", "relational", "behavioral", "contractual"],
                  "description": "Which uncertainty category this artifact reduces: structural (what exists), relational (what connects), behavioral (what happens), contractual (what's promised)"
                }
              },
              "required": ["sourcePath", "line", "kind", "name", "signature", "modifies", "calls", "insight", "reduces"]
            }
          }
        },
        "required": ["action", "response", "goalStateReached", "userPrompt", "handoffSpec", "packageManagers", "frameworks", "languages", "os", "artifacts"]
      }
    },

    "runtime_script": {
      "name": "runtime_script_output",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "action": {
            "type": "string",
            "enum": ["done", "need_user_input", "continue"]
          },
          "response": { "type": ["string", "null"] },
          "goalStateReached": { "type": ["boolean", "null"] },
          "userPrompt": {
            "anyOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "question": { "type": "string" },
                  "options": {
                    "anyOf": [
                      {
                        "type": "array",
                        "items": {
                          "anyOf": [
                            { "type": "string" },
                            {
                              "type": "object",
                              "additionalProperties": false,
                              "properties": {
                                "label": { "type": "string" },
                                "description": { "type": ["string", "null"] }
                              },
                              "required": ["label", "description"]
                            }
                          ]
                        }
                      },
                      { "type": "null" }
                    ]
                  },
                  "context": { "type": ["string", "null"] },
                  "multiSelect": { "type": ["boolean", "null"] }
                },
                "required": ["question", "options", "context", "multiSelect"]
              },
              { "type": "null" }
            ]
          },
          "goal": { "type": "string" },
          "workItems": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "objective": { "type": "string" },
                "delta": { "type": "string" },
                "agent": { "type": "string" },
                "dependencies": { "type": "array", "items": { "type": "string" } },
                "toolHint": { "type": ["string", "null"] },
                "targetPaths": { "type": ["array", "null"], "items": { "type": "string" } },
                "params": { "type": ["object", "null"] }
              },
              "required": ["id", "objective", "delta", "agent", "dependencies", "toolHint", "targetPaths", "params"]
            }
          }
        },
        "required": ["action", "response", "goalStateReached", "userPrompt", "goal", "workItems"]
      }
    }
  }
}
