{
  "$schema": "./config-schema.json",
  "$comment": "Default configuration for the harness. User config at ~/.nova/config.json overrides these values. API keys are stored in GraphD - use 'nova providers set <provider> <key>' to configure.",
  "models": {
    "$comment": "Available models are defined in packages/core/types/src/providers.ts.",
    "available": [],
    "default": ""
  },
  "agents": {
    "explorer": {
      "$comment": "Code exploration and search. Read-only tools.",
      "llm": {
        "role": "standard",
        "max_tokens": 64000,
        "temperature": 0.3
      },
      "budget": {
        "max_iterations": 12,
        "max_tool_calls": 60,
        "max_duration_ms": 120000
      },
      "tools": [
        "Read",
        "Glob",
        "Grep",
        "Bash"
      ],
      "output_schema": "explorer"
    },
    "standard": {
      "$comment": "Default agent for most tasks. Full tool access.",
      "llm": {
        "role": "standard",
        "max_tokens": 128000,
        "temperature": 0.7
      },
      "budget": {
        "max_iterations": 300,
        "max_tool_calls": 0,
        "max_duration_ms": 1000000
      },
      "tools": [
        "Read",
        "Write",
        "Edit",
        "Glob",
        "Grep",
        "Bash",
        "Skill",
        "explorer",
        "WebSearch",
        "apply_patch"
      ],
      "output_schema": "goal_driven"
    },
    "context_compactor": {
      "$comment": "Summarizes conversation history to reduce context size.",
      "llm": {
        "role": "fast",
        "max_tokens": 200000,
        "temperature": 0.3
      },
      "budget": {
        "max_iterations": 3,
        "max_tool_calls": 0,
        "max_duration_ms": 45000
      },
      "output_schema": "agent_action"
    }
  },
  "tools": {
    "bash_timeout_ms": 120000,
    "max_output_length": 10000,
    "execution_backend": "substrate",
    "executioner_workspace": "existing",
    "browser": {
      "default_screenshot_dir": "~/Desktop"
    }
  },
  "graphd": {
    "$comment": "Runtime ownership: harness-daemon embeds and starts GraphD by default; external clients use the daemon/control-plane APIs rather than talking to GraphD directly.",
    "enabled": true,
    "host": "127.0.0.1",
    "port": 9444,
    "db_path": "~/.graphd/graphd.db"
  },
  "entity_graph": {
    "enabled": false,
    "database_url": "postgresql://postgres:postgres@localhost:5432/agent_memory",
    "startup_scan": false,
    "lease_duration_sec": 30,
    "lease_wait_timeout_ms": 10000
  },
  "context": {
    "max_tokens": 200000,
    "session_ttl_ms": 7200000
  },
  "skills": {
    "enabled": true,
    "directory": ".agent/skills"
  },
  "hooks": {
    "enabled": true,
    "directory": "config/hooks"
  },
  "auth": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 9556,
    "session_expiry_days": null
  },
  "memory": {
    "enabled": false,
    "base_url": "http://localhost:3001",
    "timeout_ms": 5000
  }
}