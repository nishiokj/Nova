{
  "$schema": "./config-schema.json",
  "$comment": "Default configuration for the harness. User config at ~/.rex/config.json overrides these values. API keys are stored in GraphD - use 'rex providers set <provider> <key>' to configure.",

  "models": {
    "$comment": "Available models are defined in packages/types/src/providers.ts.",
    "available": [],
    "default": ""
  },

  "agents": {
    "routing": {
      "$comment": "Fast, cheap model for routing decisions. No tools needed.",
      "llm": {
        "role": "fast",
        "max_tokens": 200,
        "temperature": 0.1
      },
      "budget": {
        "max_iterations": 1,
        "max_tool_calls": 0,
        "max_duration_ms": 5000
      },
      "output_schema": "routing"
    },

    "simple": {
      "$comment": "Simple tasks without tool use. Quick responses.",
      "llm": {
        "role": "fast",
        "max_tokens": 4000,
        "temperature": 0.5
      },
      "budget": {
        "max_iterations": 1,
        "max_tool_calls": 0,
        "max_duration_ms": 8000
      },
      "output_schema": "agent_action"
    },

    "explorer": {
      "$comment": "Code exploration and search. Read-only tools.",
      "llm": {
        "role": "standard",
        "max_tokens": 64000,
        "temperature": 0.3
      },
      "budget": {
        "max_iterations": 8,
        "max_tool_calls": 60,
        "max_duration_ms": 90000
      },
      "tools": ["Read", "Glob", "Grep", "Bash"],
      "output_schema": "explorer"
    },

    "standard": {
      "$comment": "Default agent for most tasks. Full tool access.",
      "llm": {
        "role": "standard",
        "max_tokens": 128000,
        "temperature": 0.7
      },
      "budget": {
        "max_iterations": 50,
        "max_tool_calls": 225,
        "max_duration_ms": 1000000
      },
      "tools": ["Read", "Write", "Edit", "Glob", "Grep", "Bash", "Skill", "PromptUser", "coding", "explorer", "WebSearch"],
  "output_schema": "goal_driven"
    },

    "coding": {
      "$comment": "Deep coding tasks with high reasoning effort.",
      "llm": {
        "role": "reasoning",
        "max_tokens": 128000,
        "temperature": 0.7,
        "reasoning": { "effort": "high" }
      },
      "budget": {
        "max_iterations": 50,
        "max_tool_calls": 250,
        "max_duration_ms": 1000000
      },
      "tools": ["Read", "Write", "Edit", "Glob", "Grep", "Bash", "Skill", "PromptUser", "explorer"],
      "output_schema": "goal_driven"
    },

    "context_compactor": {
      "$comment": "Summarizes conversation history to reduce context size.",
      "llm": {
        "role": "fast",
        "max_tokens": 200000,
        "temperature": 0.3
      },
      "budget": {
        "max_iterations": 3,
        "max_tool_calls": 0,
        "max_duration_ms": 45000
      },
      "output_schema": "agent_action"
    },

    "debugger": {
      "$comment": "Debugging and error analysis.",
      "llm": {
        "role": "standard",
        "max_tokens": 16000,
        "temperature": 0.5
      },
      "budget": {
        "max_iterations": 15,
        "max_tool_calls": 45,
        "max_duration_ms": 180000
      },
      "tools": ["Read", "Write", "Edit", "Glob", "Grep", "Bash", "Skill", "PromptUser"],
      "output_schema": "agent_action"
    },

    "web_crawler": {
      "$comment": "Web search and content fetching.",
      "llm": {
        "role": "fast",
        "max_tokens": 8000,
        "temperature": 0.5
      },
      "budget": {
        "max_iterations": 15,
        "max_tool_calls": 23,
        "max_duration_ms": 180000
      },
      "tools": ["WebFetch", "WebSearch"],
      "output_schema": "agent_action"
    },

    "watcher": {
      "$comment": "Oversight agent for async mode. Answers questions, audits, quality gates. Needs enough budget to read files AND reason.",
      "llm": {
        "role": "standard",
        "max_tokens": 64000,
        "temperature": 0.3
      },
      "budget": {
        "max_iterations": 20,
        "max_tool_calls": 40,
        "max_duration_ms": 90000
      },
      "tools": ["Read", "Glob", "Grep", "Bash"],
      "output_schema": "watcher_action"
    },

    "planner": {
      "$comment": "Planning agent for async mode. Produces structured work breakdowns.",
      "llm": {
        "role": "standard",
        "max_tokens": 64000,
        "temperature": 0.3
      },
      "budget": {
        "max_iterations": 15,
        "max_tool_calls": 60,
        "max_duration_ms": 180000
      },
      "tools": ["Read", "Glob", "Grep", "PromptUser"],
      "output_schema": "planner_output"
    }
  },

  "tools": {
    "bash_timeout_ms": 120000,
    "max_output_length": 10000,
    "browser": {
      "default_screenshot_dir": "~/Desktop"
    }
  },

  "graphd": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 9444,
    "db_path": "~/.graphd/graphd.db"
  },

  "entity_graph": {
    "enabled": true,
    "database_url": "postgresql://postgres:postgres@localhost:5432/agent_memory",
    "startup_scan": true,
    "lease_duration_sec": 30,
    "lease_wait_timeout_ms": 10000
  },

  "context": {
    "max_tokens": 200000,
    "session_ttl_ms": 7200000
  },

  "skills": {
    "enabled": true,
    "directory": "config/skills"
  },

  "hooks": {
    "enabled": true,
    "directory": "config/hooks"
  },

  "auth": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 9556,
    "session_expiry_days": null
  },

  "memory": {
    "enabled": true,
    "base_url": "http://localhost:3001",
    "timeout_ms": 5000
  }
}
