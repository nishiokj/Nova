{
  "id": "post-task-code-review",
  "name": "Post-Task Code Review",
  "description": "Automatic code review after task completion. Analyzes scope, writes, bugs, second-order effects via graphd, and backwards-compat slop.",
  "enabled": true,
  "trigger": "task.completed",
  "priority": 100,
  "timeout_ms": 10000,
  "fail_open": true,
  "filter": {},
  "action": {
    "type": "mutate",
    "ops": [
      {
        "op": "trigger_code_review",
        "value": {
          "check_scope": true,
          "check_writes": true,
          "check_bugs": true,
          "check_effects": true,
          "check_slop": true
        }
      }
    ]
  },
  "created_at": "2026-01-01T00:00:00Z",
  "updated_at": "2026-01-01T00:00:00Z"
}
