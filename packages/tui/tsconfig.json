{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "bun"]
  },
  "include": ["*.ts", "*.tsx", "components/**/*.ts", "components/**/*.tsx", "utils/**/*.ts"]
}
