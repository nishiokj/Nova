{
  "name": "memory-injector",
  "version": "0.1.0",
  "description": "Stateless retrieval layer that injects relevant memory into agent context",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:unit": "bun test **/*.unit.test.ts",
    "test:e2e": "bun test **/*.e2e.test.ts"
  },
  "dependencies": {
    "agent-memory": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
