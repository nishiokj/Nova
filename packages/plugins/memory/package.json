{
  "name": "memory",
  "version": "0.1.0",
  "description": "Unified memory plugin that bundles agent-memory, entity-graph, and memory-injector",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
