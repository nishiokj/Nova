{
  "name": "agent-memory",
  "version": "0.1.0",
  "description": "Agent memory system with connector SDK, sync engine, and entity resolution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "lint:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "clean": "rm -rf dist",
    "daemon": "bash ./scripts/start.sh",
    "daemon:only": "bun run scripts/sync-daemon.ts",
    "db:start": "AGENT_MEMORY_DB_ONLY=1 bash ./scripts/start.sh",
    "kill": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
    "db:migrate": "bun run scripts/migrate.ts",
    "register": "bun run scripts/register-connector.ts",
    "setup": "bun run scripts/setup.ts"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "harness-client": "workspace:*",
    "ngrok": "^5.0.0-beta.2",
    "open": "^10.1.0",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.8",
    "semantic-compiler": "workspace:*",
    "types": "workspace:*",
    "ulid": "^2.3.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
