{
  "name": "harness-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "nova-daemon": "./bin/nova.js"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "profile": "bun --inspect run src/index.ts",
    "profile:cpu": "BUN_JSC_dumpSamplingProfilerData=1 bun run src/index.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target node"
  },
  "dependencies": {
    "@substrate/sdk": "file:../../../../substrate/packages/executioner-js",
    "agent": "workspace:*",
    "comms-bus": "workspace:*",
    "context": "workspace:*",
    "effect": "^3.19.18",
    "harness-client": "workspace:*",
    "graphd": "workspace:*",
    "llm": "workspace:*",
    "minimatch": "^10.1.1",
    "orchestrator": "workspace:*",
    "runtime": "workspace:*",
    "shared": "workspace:*",
    "tools": "workspace:*",
    "types": "workspace:*",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
