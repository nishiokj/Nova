{
  "name": "tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "bun run index.tsx",
    "start": "bun run index.tsx",
    "build": "bun build index.tsx --outdir dist --target node && cp node_modules/yoga-wasm-web/dist/yoga.wasm dist/yoga.wasm",
    "clean": "rm -rf dist",
    "lint": "bun tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "comms-bus": "workspace:*",
    "entity-graph": "workspace:*",
    "harness-client": "workspace:*",
    "ink": "^4.4.1",
    "marked": "^17.0.1",
    "marked-terminal": "^7.3.0",
    "react": "^18.3.1",
    "string-width": "^8.1.0",
    "strip-ansi": "^7.1.2",
    "tree-sitter": "^0.22.4",
    "types": "workspace:*",
    "wrap-ansi": "^9.0.2"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^18.2.0",
    "ink-testing-library": "^3.0.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-reconciler": {
      "react": "^18.3.1"
    }
  }
}
