{
  "name": "agent-core",
  "version": "0.1.0",
  "description": "Composable agent primitives: Agent, Orchestrator, ContextWindow, ToolRegistry, and LLM adapters",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./shared": {
      "import": "./dist/shared/index.js",
      "types": "./dist/shared/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "npx tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agent",
    "llm",
    "orchestrator",
    "ai",
    "anthropic",
    "openai"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/uuid": "^11.0.0",
    "fast-glob": "^3.3.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
