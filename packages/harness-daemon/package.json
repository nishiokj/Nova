{
  "name": "harness-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "bun run src/index.ts",
    "profile": "bun --inspect run src/index.ts",
    "profile:cpu": "BUN_JSC_dumpSamplingProfilerData=1 bun run src/index.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build": "tsc",
    "test": "bun test"
  },
  "dependencies": {
    "agent": "workspace:*",
    "comms-bus": "workspace:*",
    "context": "workspace:*",
    "entity-graph": "workspace:*",
    "graphd": "workspace:*",
    "llm": "workspace:*",
    "memory-injector": "workspace:*",
    "minimatch": "^10.1.1",
    "orchestrator": "workspace:*",
    "shared": "workspace:*",
    "tools": "workspace:*",
    "types": "workspace:*",
    "decision-watcher": "workspace:*",
    "work": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
