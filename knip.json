{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": [
    ".lab/**",
    "**/dist/**",
    ".agent/skills/**"
  ],
  "ignoreDependencies": [
    "typescript",
    "autoprefixer",
    "postcss",
    "tailwindcss",
    "ink-testing-library"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.{ts,js,mjs}",
        "tests/**/*.test.ts"
      ],
      "project": [
        "scripts/**/*.{ts,js,mjs}",
        "tests/**/*.test.ts"
      ]
    },
    "packages/core/types": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core/shared": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core/protocol": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/external/prompt-protocol": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core/work": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core/llm": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core/context": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core/tools": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core/agent": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/plugins/agent-memory": {
      "entry": ["src/index.ts", "src/connectors/telegram/index.ts", "src/connectors/telegram/types.ts", "scripts/**/*.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/infra/comms-bus": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/plugins/entity-graph": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/infra/graphd": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/infra/harness-client": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/infra/experiment-proxy": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/infra/harness-daemon": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/plugins/memory-injector": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core/orchestrator": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/apps/launcher": {
      "entry": ["index.ts", "standalone.ts"],
      "project": ["**/*.ts"]
    },
    "packages/apps/tui": {
      "entry": ["main.ts", "index.tsx", "components/index.ts", "**/*.test.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/apps/dashboard": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/apps/dashboard-compact": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
