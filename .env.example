# =============================================================================
# Voice Agent System - Environment Configuration
# =============================================================================
#
# This file documents all environment variables supported by the Voice Agent System.
# Copy this file to .env and fill in your values.
#
# IMPORTANT: Never commit .env files containing real API keys to version control!
#

# =============================================================================
# LLM API KEYS (At least one required)
# =============================================================================
# The voice agent requires at least one LLM provider API key to function.
# Keys are auto-detected based on the provider configured in harness_config.json.

# OpenAI API Key (for GPT models)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Anthropic API Key (for Claude models)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google API Key (for Gemini models)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here


# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Override logging settings from app_config.json

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Directory for log files (relative or absolute path)
LOG_DIR=logs


# =============================================================================
# STT (SPEECH-TO-TEXT) CONFIGURATION OVERRIDES
# =============================================================================
# Override STT settings from app_config.json
# Useful for testing different models or devices without editing config files

# Whisper model size
# Options: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en, large-v3
# English-only models (*.en) are faster and more accurate for English
#STT_MODEL=base.en

# STT device selection
# Options:
#   auto  - Auto-detect best available device (recommended)
#   cpu   - Force CPU inference (slower but compatible)
#   cuda  - Force NVIDIA GPU (requires CUDA)
#   mps   - Force Apple Metal (M1/M2/M3 Macs)
#STT_DEVICE=auto

# Compute type for faster-whisper
# Options: auto, int8, float16, float32
# int8 is fastest but less accurate, float32 is most accurate but slowest
#STT_COMPUTE_TYPE=auto


# =============================================================================
# TTS (TEXT-TO-SPEECH) CONFIGURATION OVERRIDES
# =============================================================================
# Override TTS settings from app_config.json
# Change the voice to make it sound more natural and personable!

# TTS voice name
# macOS voices: Samantha (default), Alex (male), Karen (Australian), Moira (Irish),
#               Tessa (South African), Fiona (Scottish), Daniel (British)
# Run `say -v "?"` on macOS to see all available voices
# For pyttsx3: depends on system voices installed
#TTS_VOICE=Samantha

# Speech rate in words per minute
# Default: 200 (range: 90-300, 200 is conversational)
# Lower = slower/clearer, Higher = faster
#TTS_RATE=200

# Volume level (0.0 to 1.0)
# Default: 0.9
#TTS_VOLUME=0.9


# =============================================================================
# AUDIO CONFIGURATION OVERRIDES
# =============================================================================
# Override audio settings from app_config.json

# Audio input device index
# Use `voice-agent --list-devices` to see available devices
# Leave unset to use system default microphone
#AUDIO_DEVICE_INDEX=0

# Audio sample rate in Hz
# Recommended: 16000, 32000, or 48000 (must be compatible with VAD)
#AUDIO_SAMPLE_RATE=32000


# =============================================================================
# HARNESS CONFIGURATION OVERRIDES
# =============================================================================
# Override harness settings from app_config.json

# Path to harness configuration file
# Useful for switching between different agent configurations
#HARNESS_CONFIG_PATH=config/harness_config.json


# =============================================================================
# DOCKER-SPECIFIC CONFIGURATION
# =============================================================================
# These variables are typically only needed when running in Docker

# PulseAudio server address (Linux containers with PulseAudio)
# Example for user UID 1000:
#PULSE_SERVER=unix:/run/user/1000/pulse/native

# NVIDIA GPU visibility (for GPU-accelerated Docker containers)
# Usually set automatically by docker-compose.yml
#NVIDIA_VISIBLE_DEVICES=all
#NVIDIA_DRIVER_CAPABILITIES=compute,utility


# =============================================================================
# ADVANCED / OPTIONAL
# =============================================================================

# Enable structured logging (JSON format)
# Useful for log aggregation tools like ELK, Splunk, etc.
#STRUCTURED_LOGGING=true

# Custom audio log level (separate from main LOG_LEVEL)
#AUDIO_LOG_LEVEL=DEBUG
