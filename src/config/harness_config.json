{
  "router": {
    "enabled": true,
    "default_tier": "standard",
    "difficulty_tiers": ["simple", "standard", "advanced"]
  },
  "service_rep": {
    "enabled": true,
    "voice_engine": "pyttsx3",
    "voice_rate": 190,
    "voice_volume": 0.65
  },
  "agent": {
    "tier": "standard",
    "max_tool_calls": 15,
    "tool_timeout": 30,
    "allow_code_execution": true,
    "allow_internet": true,
    "allow_bash": true,
    "tier_tool_limits": {
      "simple": 1,
      "standard": 5,
      "advanced": 25
    },
    "tier_max_tokens": {
      "simple": 1500,
      "standard": 4000,
      "advanced": 32000
    }
  },
  "tools": {
      "enabled_tools": [
        "fast_answer",
        "web_fetch",
        "bash_execute",
        "python_execute",
        "file_read",
        "file_write",
        "search_filesystem",
        "calculator",
        "get_current_time",
        "get_working_directory",
        "list_files"
      ],
    "sandbox_bash": true,
    "sandbox_python": true,
    "max_output_length": 10000,
    "bash_timeout": 30,
    "python_timeout": 60
  },
  "logging": {
    "log_dir": "logs",
    "log_level": "INFO",
    "log_to_file": true,
    "log_to_console": true,
    "structured_format": true
  },
