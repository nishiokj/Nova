{
  "default_agent": {
    "type": "TieredAgent",
    "module": "harness.agent",
    "class": "TieredAgent",
    "tier": "advanced",
    "llm_config": {
      "provider": "openai",
      "model": "gpt-4o",
      "temperature": 0.7,
      "max_tokens": 16000
    },
    "tool_config": {
      "enabled_tools": [
        "web_search",
        "fast_answer",
        "file_read",
        "file_write",
        "python_execute",
        "bash_execute",
        "calculator",
        "get_current_time",
        "list_files",
        "search_filesystem"
      ]
    }
  },

  "agents": {
    "tiered_simple": {
      "type": "TieredAgent",
      "module": "harness.agent",
      "class": "TieredAgent",
      "tier": "simple",
      "llm_config": {
        "provider": "openai",
        "model": "gpt-5-nano",
        "temperature": 0.7,
        "max_tokens": 4000
      }
    },

    "tiered_advanced": {
      "type": "TieredAgent",
      "module": "harness.agent",
      "class": "TieredAgent",
      "tier": "advanced",
      "llm_config": {
        "provider": "openai",
        "model": "gpt-5.1",
        "temperature": 0.7,
        "max_tokens": 8000
      }
    },

    "claude_sonnet": {
      "type": "TieredAgent",
      "module": "harness.agent",
      "class": "TieredAgent",
      "tier": "advanced",
      "llm_config": {
        "provider": "anthropic",
        "model": "claude-sonnet-4-5",
        "temperature": 0.7,
        "max_tokens": 4000
      }
    },

    "routed_agent": {
      "type": "RoutedAgent",
      "module": "harness.agent",
      "class": "TieredAgent",
      "use_router": true,
      "router_config": {
        "enabled": true,
        "llm_config": {
          "provider": "openai",
          "model": "gpt-5-nano",
          "temperature": 0.0,
          "max_tokens": 2000
        }
      },
      "llm_config": {
        "provider": "openai",
        "model": "gpt-5-nano",
        "temperature": 0.7,
        "max_tokens": 4000
      },
      "tier_configs": {
        "simple": {
          "provider": "openai",
          "model": "gpt-5-nano",
          "temperature": 0.5,
          "max_tokens": 3000
        },
        "standard": {
          "provider": "openai",
          "model": "gpt-5-mini",
          "temperature": 0.7,
          "max_tokens": 4000
        },
        "advanced": {
          "provider": "openai",
          "model": "gpt-5.1",
          "temperature": 0.7,
          "max_tokens": 8000
        }
      }
    },

    "custom_agent": {
      "type": "CustomAgent",
      "module": "path.to.your.agent",
      "class": "YourAgentClass",
      "init_params": {
        "custom_param_1": "value1",
        "custom_param_2": "value2"
      },
      "llm_config": {
        "provider": "openai",
        "model": "gpt-4o",
        "temperature": 0.7,
        "max_tokens": 4000
      }
    }
  }
}
