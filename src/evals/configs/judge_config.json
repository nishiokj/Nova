{
  "default_judge": {
    "provider": "openai",
    "model": "gpt-5.1",
    "temperature": 0,
    "max_tokens": 4000,
    "note": "Temperature MUST be 0 for reproducible grading"
  },

  "alternative_judges": {
    "gpt4": {
      "provider": "openai",
      "model": "gpt-4-turbo",
      "temperature": 0,
      "max_tokens": 4000
    },
    "claude_sonnet": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5",
      "temperature": 0,
      "max_tokens": 4000
    }
  },

  "grading_parameters": {
    "require_evidence": true,
    "binary_questions_only": true,
    "temperature": 0,
    "deterministic_mode": true
  },

  "retry_policy": {
    "max_retries": 2,
    "retry_on_parse_failure": true,
    "retry_delay_seconds": 1
  }
}
