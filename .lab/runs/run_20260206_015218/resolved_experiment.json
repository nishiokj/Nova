{
  "analysis_plan": {
    "missingness": {
      "policy": "paired_drop",
      "record_reasons": true
    },
    "multiple_comparisons": {
      "method": "none"
    },
    "primary_metrics": [
      "success"
    ],
    "reporting": {
      "effect_sizes": [
        "risk_diff",
        "median_diff"
      ],
      "show_task_level_table": true
    },
    "secondary_metrics": [
      "latency_ms"
    ],
    "tests": {
      "latency_ms": {
        "ci": 0.95,
        "method": "paired_bootstrap",
        "resamples": 1000
      },
      "success": {
        "ci": 0.95,
        "method": "paired_bootstrap",
        "resamples": 1000
      }
    }
  },
  "baseline": {
    "bindings": {},
    "variant_id": "base"
  },
  "dataset": {
    "limit": 50,
    "path": "tasks.jsonl",
    "provider": "local_jsonl",
    "schema_version": "task_jsonl_v1",
    "split_id": "dev",
    "suite_id": "local_suite"
  },
  "design": {
    "comparison": "paired",
    "max_concurrency": 1,
    "random_seed": 1337,
    "replications": 1,
    "sanitization_profile": "hermetic_functional_v2",
    "shuffle_tasks": true
  },
  "experiment": {
    "description": "Generated by lab init",
    "id": "exp_local",
    "name": "AgentLab Experiment",
    "owner": "you",
    "tags": [
      "example"
    ]
  },
  "runtime": {
    "harness": {
      "command": [
        "bun",
        "./scripts/agentlab/run_cli.ts"
      ],
      "control_plane": {
        "mode": "file",
        "path": "/state/lab_control.json"
      },
      "input_path": "/out/trial_input.json",
      "integration_level": "cli_events",
      "mode": "cli",
      "output_path": "/out/trial_output.json"
    },
    "network": {
      "allowed_hosts": [],
      "mode": "none"
    },
    "sandbox": {
      "engine": "docker",
      "hardening": {
        "drop_all_caps": true,
        "no_new_privileges": true
      },
      "image": "oven/bun:1",
      "mode": "container",
      "resources": {
        "cpu_count": 2,
        "memory_mb": 2048
      },
      "root_read_only": true,
      "run_as_user": "1000:1000"
    }
  },
  "validity": {
    "fail_on_profile_invariant_violation": true,
    "fail_on_state_leak": true
  },
  "variants": [],
  "version": "0.3"
}